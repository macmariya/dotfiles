# Secrets（setup-secrets.sh は追跡可能にする）
secrets/*.local
secrets/.env*
*.local
!bin/.local
.env*
!.env.example

# macOS
.DS_Store
._*

# ツール
.bootstrap.log
.claude/

# ローカル設定
**/local.zsh

# SSH ホスト固有設定（config.d/ 内のファイル）
ssh/.ssh/config.d/*
!ssh/.ssh/config.d/.gitkeep

# SSH / GPG 鍵（誤コミット防止）
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
secring.*

# AWS 認証情報
.aws/credentials

# その他シークレット系
*.secret
credentials.json
