# =============================================================================
# Ghostty 設定ファイル
# macOS (Apple Silicon M5) + 日本語環境対応
# =============================================================================

# -----------------------------------------------------------------------------
# フォント設定
# -----------------------------------------------------------------------------

# メインフォント: HackGen Console NF（日本語対応 Nerd Font）
# インストール: brew install --cask font-hackgen-console-nf
font-family = HackGen Console NF

# フォールバック（HackGen が見つからない場合）
# font-family = "JetBrainsMono Nerd Font"
# font-family = "Hack Nerd Font"
# font-family = "Source Code Pro"

# フォントサイズ（pt）
font-size = 14

# フォントの太さ調整（任意）
# font-thicken = true

# -----------------------------------------------------------------------------
# テーマ・カラー設定
# -----------------------------------------------------------------------------

# テーマ: Catppuccin Mocha（Ghostty 組み込みテーマ）
# 利用可能テーマ一覧: ghostty +list-themes
theme = catppuccin-mocha

# -----------------------------------------------------------------------------
# ウィンドウ設定
# -----------------------------------------------------------------------------

# 内側の余白（上下, 左右）単位: px
window-padding-x = 12
window-padding-y = 10

# バランスパディング（ペイン分割時の均等余白）
window-padding-balance = true

# 起動時のウィンドウサイズ（列 x 行）
window-width = 220
window-height = 50

# ウィンドウを装飾なし（タイトルバー非表示）にする場合
# window-decoration = false

# -----------------------------------------------------------------------------
# カーソル設定
# -----------------------------------------------------------------------------

# カーソル形状: block | bar | underline
cursor-style = block

# カーソルの点滅
cursor-style-blink = true

# -----------------------------------------------------------------------------
# シェル統合
# -----------------------------------------------------------------------------

# シェル統合を有効化（zsh 対応）
# プロンプトの検知、コマンド実行追跡、タイトル更新などを自動化
shell-integration = zsh

# シェル統合の機能フラグ（必要に応じてコメント解除）
# shell-integration-features = cursor,sudo,title

# -----------------------------------------------------------------------------
# macOS ネイティブ設定
# -----------------------------------------------------------------------------

# タイトルバースタイル: native | transparent | hidden
# transparent にすることでウィンドウと一体化したモダンな外観に
macos-titlebar-style = transparent

# Option キーを Alt として扱う（左 Option のみ）
# Vim の Meta キーや zsh の単語移動（Alt+b, Alt+f）に必要
macos-option-as-alt = left

# macOS の秘密キーチェーンとの統合
# macos-secure-keyboard-entry = true

# Dock アイコンを非表示（純粋にターミナルとして使う場合）
# macos-hide-from-tasks = false

# -----------------------------------------------------------------------------
# 日本語入力対応
# -----------------------------------------------------------------------------

# IME（インライン入力）を有効化
# Ghostty はデフォルトで macOS IME に対応しているため通常設定不要
# 問題がある場合は以下を試す
# gtk-single-instance = false

# -----------------------------------------------------------------------------
# キーバインド設定
# -----------------------------------------------------------------------------

# スーパーキー（Cmd）+ Enter でフルスクリーン切り替え
keybind = super+enter=toggle_fullscreen

# Cmd + Shift + , で設定ファイルを再読み込み
keybind = super+shift+comma=reload_config

# Cmd + Shift + / で設定ファイルを開く
# keybind = super+shift+slash=open_config

# タブ操作
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab

# 分割ペイン（tmux と組み合わせる場合は不要なことも）
# keybind = super+d=new_split:right
# keybind = super+shift+d=new_split:down

# -----------------------------------------------------------------------------
# スクロール設定
# -----------------------------------------------------------------------------

# スクロールバッファ行数
scrollback-limit = 10000

# マウスホイールのスクロール速度（倍率）
# mouse-scroll-multiplier = 3

# -----------------------------------------------------------------------------
# 外観・レンダリング設定
# -----------------------------------------------------------------------------

# ウィンドウ透明度（0.0 = 完全透明, 1.0 = 不透明）
# 半透明にする場合は background-opacity と blur を合わせて使う
# background-opacity = 0.95
# background-blur-radius = 20

# リフレッシュレートに合わせた垂直同期
# vsync = true

# ウィンドウを閉じる際に確認ダイアログを表示
confirm-close-surface = false

# 起動時に前回のウィンドウを復元
# window-save-state = default

# -----------------------------------------------------------------------------
# クリップボード設定
# -----------------------------------------------------------------------------

# クリップボードへのアクセスを許可
clipboard-read = allow
clipboard-write = allow

# ブラケットペーストを有効化（Vim 等での誤入力防止）
# bracketed-paste = true

# -----------------------------------------------------------------------------
# ベル設定
# -----------------------------------------------------------------------------

# 視覚的なベルのみ（音を鳴らさない）
# ベル無効化（Ghostty は音声ベルをデフォルトで鳴らさない）
# 必要に応じて visible-bell を設定
